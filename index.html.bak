<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MTRX LIBRARY — Banco de Prompts</title>
<style>
  :root {
    --bg: #0a0a0a;
    --bg2: #111111;
    --bg3: #181818;
    --border: #222222;
    --border-hover: #333333;
    --accent: #FF4500;
    --accent2: #FF6B35;
    --accent-dim: rgba(255,69,0,0.08);
    --text: #f0f0f0;
    --text2: #888888;
    --text3: #555555;
    --red: #ff4444;
    --green: #44ff88;
    --tag-img: #7c3aed;
    --tag-aud: #0891b2;
    --radius: 12px;
    --radius-sm: 8px;
    --font: 'Inter', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'Fira Code', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    min-height: 100vh;
    line-height: 1.6;
  }

  /* ── HEADER ── */
  header {
    border-bottom: 1px solid var(--border);
    padding: 20px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .logo {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 4px;
    color: var(--accent);
    font-family: var(--mono);
  }

  .logo span { color: var(--text2); }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .admin-badge {
    display: none;
    background: var(--accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    padding: 4px 10px;
    border-radius: 4px;
  }

  .admin-badge.visible { display: block; }

  #adminToggleBtn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text3);
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 1px;
  }

  #adminToggleBtn:hover { border-color: var(--accent); color: var(--accent); }

  /* ── HERO ── */
  .hero {
    padding: 64px 32px 40px;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-tag {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .hero h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 16px;
    letter-spacing: -1px;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .hero p {
    font-size: 16px;
    color: var(--text2);
    max-width: 560px;
    line-height: 1.7;
  }

  /* ── SEARCH & FILTERS ── */
  .controls {
    padding: 0 32px 32px;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
  }

  .search-wrap svg {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text3);
  }

  #searchInput {
    width: 100%;
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 10px 14px 10px 40px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  #searchInput:focus { border-color: var(--accent); }
  #searchInput::placeholder { color: var(--text3); }

  .filter-btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text2);
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
  }

  .filter-btn:hover { border-color: var(--border-hover); color: var(--text); }
  .filter-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 700; }

  /* ── FEATURED STRIP ── */
  .featured-section {
    padding: 0 32px 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--text3);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .featured-strip {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .featured-chip {
    background: var(--accent-dim);
    border: 1px solid rgba(255,69,0,0.25);
    color: var(--accent);
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .featured-chip:hover { background: rgba(255,69,0,0.18); border-color: var(--accent); }

  /* ── CATEGORIES ── */
  .main-content {
    padding: 0 32px 80px;
    max-width: 900px;
    margin: 0 auto;
  }

  .category-block {
    margin-bottom: 48px;
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .category-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cat-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  .cat-icon.img { background: rgba(124,58,237,0.15); }
  .cat-icon.aud { background: rgba(8,145,178,0.15); }

  .cat-name {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .cat-count {
    font-size: 12px;
    color: var(--text3);
    margin-top: 2px;
  }

  .btn-add-cat {
    display: none;
    background: var(--bg2);
    border: 1px dashed var(--border);
    color: var(--text3);
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    gap: 6px;
    align-items: center;
  }

  .btn-add-cat:hover { border-color: var(--accent); color: var(--accent); }

  /* ── SUBCATEGORY ── */
  .subcategory {
    margin-bottom: 28px;
  }

  .sub-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .sub-name {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text2);
    text-transform: uppercase;
  }

  .btn-add-sub {
    display: none;
    background: transparent;
    border: none;
    color: var(--text3);
    font-size: 12px;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 4px;
    transition: all 0.2s;
    gap: 4px;
    align-items: center;
  }

  .btn-add-sub:hover { color: var(--accent); background: var(--accent-dim); }

  /* ── PROMPT CARDS ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
  }

  .prompt-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    position: relative;
    transition: border-color 0.2s, background 0.2s;
    cursor: default;
  }

  .prompt-card:hover {
    border-color: var(--border-hover);
    background: var(--bg3);
  }

  .prompt-card.featured {
    border-color: rgba(255,69,0,0.3);
    background: linear-gradient(135deg, var(--bg3) 0%, rgba(255,69,0,0.04) 100%);
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .card-title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    flex: 1;
    padding-right: 8px;
  }

  .card-actions {
    display: flex;
    gap: 4px;
    align-items: center;
    flex-shrink: 0;
  }

  .btn-fav, .btn-edit, .btn-delete, .btn-copy {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    line-height: 1;
  }

  .btn-fav { color: var(--text3); }
  .btn-fav:hover { color: var(--accent); }
  .btn-fav.active { color: var(--accent); }

  .btn-copy { color: var(--text3); }
  .btn-copy:hover { color: var(--accent2); }

  .btn-edit { color: var(--text3); display: none; }
  .btn-edit:hover { color: var(--accent); }

  .btn-delete { color: var(--text3); display: none; }
  .btn-delete:hover { color: var(--red); }

  .card-desc {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .card-prompt {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 10px 12px;
    font-size: 12px;
    font-family: var(--mono);
    color: #FF6B35;
    line-height: 1.5;
    word-break: break-word;
    cursor: pointer;
    transition: border-color 0.2s;
    position: relative;
  }

  .card-prompt:hover { border-color: var(--accent2); }

  .prompt-copied-msg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--accent);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 10px;
  }

  .tag {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
  }

  .tag.img { background: rgba(124,58,237,0.15); color: #a78bfa; }
  .tag.aud { background: rgba(8,145,178,0.15); color: #67e8f9; }
  .tag.featured-tag { background: rgba(255,69,0,0.12); color: var(--accent); }

  /* ── ADMIN PANEL ── */
  #adminPanel {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(10,10,10,0.98);
    border-top: 2px solid var(--accent);
    padding: 14px 32px;
    z-index: 200;
    backdrop-filter: blur(16px);
  }

  #adminPanel.visible { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

  .admin-info {
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 2px;
    flex: 1;
  }

  .btn-exit-admin {
    background: transparent;
    border: 1px solid var(--red);
    color: var(--red);
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-exit-admin:hover { background: var(--red); color: #fff; }

  /* ── MODAL ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 300;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .modal-overlay.visible { display: flex; }

  .modal {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 90%;
    max-width: 480px;
    position: relative;
  }

  .modal h2 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: -0.5px;
  }

  .modal h2 em {
    font-style: normal;
    color: var(--accent);
  }

  .form-group {
    margin-bottom: 16px;
  }

  .form-group label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--text2);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
    font-family: var(--font);
  }

  .form-group textarea { min-height: 80px; resize: vertical; }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus { border-color: var(--accent); }

  .form-group select option { background: var(--bg2); }

  .modal-footer {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 24px;
  }

  .btn-cancel {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text2);
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-cancel:hover { border-color: var(--text2); color: var(--text); }

  .btn-save {
    background: var(--accent);
    border: none;
    color: #fff;
    padding: 10px 24px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-save:hover { opacity: 0.85; }

  /* ── PASSWORD MODAL ── */
  #pwModal .modal { max-width: 380px; text-align: center; }
  #pwModal .modal h2 { font-size: 16px; color: var(--text2); margin-bottom: 20px; }

  #pwInput {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    font-size: 20px;
    text-align: center;
    letter-spacing: 4px;
    outline: none;
    font-family: var(--mono);
    margin-bottom: 16px;
    transition: border-color 0.2s;
  }

  #pwInput:focus { border-color: var(--accent); }
  #pwError { color: var(--red); font-size: 13px; min-height: 20px; margin-bottom: 12px; }

  .btn-unlock {
    width: 100%;
    background: var(--accent);
    border: none;
    color: #fff;
    padding: 12px;
    border-radius: var(--radius-sm);
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn-unlock:hover { opacity: 0.85; }

  /* ── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--text3);
  }

  .empty-state svg { margin-bottom: 16px; opacity: 0.3; }
  .empty-state p { font-size: 14px; }

  /* ── TOAST ── */
  #toast {
    position: fixed;
    bottom: 80px;
    right: 32px;
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 20px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    z-index: 999;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s;
    pointer-events: none;
  }

  #toast.show { opacity: 1; transform: translateY(0); }
  #toast.success { border-color: var(--green); color: var(--green); }
  #toast.error { border-color: var(--red); color: var(--red); }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    header { padding: 16px 20px; }
    .hero { padding: 40px 20px 24px; }
    .controls { padding: 0 20px 24px; }
    .featured-section, .main-content { padding-left: 20px; padding-right: 20px; }
    .cards-grid { grid-template-columns: 1fr; }
    #adminPanel.visible { padding: 12px 20px; }
  }

  /* ── ADMIN MODE REVEALS ── */
  body.admin-mode .btn-edit { display: flex !important; }
  body.admin-mode .btn-delete { display: flex !important; }
  body.admin-mode .btn-add-cat { display: flex !important; }
  body.admin-mode .btn-add-sub { display: flex !important; }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo"><span style="color:#FF4500">M</span><span style="color:#fff">TR</span><span style="color:#FF4500">X</span><span style="color:#555">_</span><span style="color:#fff">LIBRARY</span></div>
  <div class="header-right">
    <span class="admin-badge" id="adminBadge">● ADMIN MODE</span>
    <button id="adminToggleBtn" onclick="openPasswordModal()">⚿ Admin</button>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-tag">Creative Prompt Database</div>
  <h1>Liberdade de criar.<br><em>Sem bloqueio criativo.</em></h1>
  <p>Um repositório vivo de prompts para imagem e áudio. Acesse os comandos certos na hora certa — e nunca mais fique parado sem ideia.</p>
</section>

<!-- CONTROLS -->
<div class="controls">
  <div class="search-wrap">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input type="text" id="searchInput" placeholder="Buscar prompts..." oninput="renderAll()">
  </div>
  <div class="filter-btns">
    <button class="filter-btn active" onclick="setFilter('all', this)">Todos</button>
    <button class="filter-btn" onclick="setFilter('image', this)">🖼 Imagem</button>
    <button class="filter-btn" onclick="setFilter('audio', this)">🎵 Áudio</button>
    <button class="filter-btn" onclick="setFilter('featured', this)">⭐ Curadoria</button>
  </div>
</div>

<!-- FEATURED -->
<div class="featured-section" id="featuredSection">
  <div class="section-label">⭐ Curadoria do Time</div>
  <div class="featured-strip" id="featuredStrip"></div>
</div>

<!-- MAIN CONTENT -->
<main class="main-content" id="mainContent"></main>

<!-- ADMIN PANEL -->
<div id="adminPanel">
  <div class="admin-info">⚡ MODO ADMIN ATIVO — Você pode adicionar, editar e deletar prompts</div>
  <button class="btn-exit-admin" onclick="exitAdmin()">Sair do Admin</button>
</div>

<!-- TOAST -->
<div id="toast"></div>

<!-- PASSWORD MODAL -->
<div class="modal-overlay" id="pwModal">
  <div class="modal">
    <h2>🔐 Acesso Administrativo</h2>
    <input type="password" id="pwInput" placeholder="••••••" onkeydown="if(event.key==='Enter') checkPassword()">
    <div id="pwError"></div>
    <button class="btn-unlock" onclick="checkPassword()">Desbloquear</button>
    <br><br>
    <button class="btn-cancel" onclick="closeModal('pwModal')" style="width:100%">Cancelar</button>
  </div>
</div>

<!-- ADD/EDIT PROMPT MODAL -->
<div class="modal-overlay" id="promptModal">
  <div class="modal">
    <h2 id="promptModalTitle">Adicionar <em>Prompt</em></h2>
    <div class="form-group">
      <label>Categoria</label>
      <select id="formCategory">
        <option value="image">🖼 Imagem</option>
        <option value="audio">🎵 Áudio</option>
      </select>
    </div>
    <div class="form-group">
      <label>Subcategoria</label>
      <input type="text" id="formSubcategory" placeholder="Ex: Ângulos de Câmera, Gêneros Musicais...">
    </div>
    <div class="form-group">
      <label>Nome do Prompt</label>
      <input type="text" id="formTitle" placeholder="Ex: Close-up, Sertanejo, Voz Grossa...">
    </div>
    <div class="form-group">
      <label>Descrição</label>
      <textarea id="formDesc" placeholder="O que este prompt faz? Qual o impacto criativo?"></textarea>
    </div>
    <div class="form-group">
      <label>Prompt (texto copiável)</label>
      <textarea id="formPrompt" placeholder="O texto exato do prompt para copiar e usar na IA..."></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal('promptModal')">Cancelar</button>
      <button class="btn-save" onclick="savePrompt()">Salvar Prompt</button>
    </div>
  </div>
</div>

<script>
// ─────────────────────────────────────────────
// ADMIN PASSWORD
// ─────────────────────────────────────────────
const ADMIN_CODE = 'mtrx2024';

// ─────────────────────────────────────────────
// DEFAULT DATA
// ─────────────────────────────────────────────
const DEFAULT_DATA = {
  categories: [
    {
      id: 'image',
      name: 'Prompts de Imagem',
      type: 'image',
      icon: '🖼',
      subcategories: [
        {
          id: 'sub_angles',
          name: 'Ângulos de Câmera',
          prompts: [
            {
              id: 'p1',
              title: 'Close-up',
              desc: 'Visão de perto. Enfatiza emoção, detalhes faciais e textura. Cria conexão imediata com o sujeito.',
              prompt: 'close-up shot, macro detail, facial focus, sharp eyes, 8k resolution, bokeh background',
              featured: true
            },
            {
              id: 'p2',
              title: 'Wide Shot',
