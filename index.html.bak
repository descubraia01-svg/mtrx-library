};

// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
let db = loadDB();
let isAdmin = localStorage.getItem('mtrx_admin') === 'true';
let currentFilter = 'all';
let editingPromptRef = null; // {categoryId, subcategoryId, promptId}

function loadDB() {
  const saved = localStorage.getItem('mtrx_db');
  if (saved) {
    try { return JSON.parse(saved); } catch(e) {}
  }
  return JSON.parse(JSON.stringify(DEFAULT_DATA));
}

function saveDB() {
  localStorage.setItem('mtrx_db', JSON.stringify(db));
}

function genId() {
  return 'p_' + Date.now() + '_' + Math.random().toString(36).slice(2,7);
}

// ─────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────
function openPasswordModal() {
  if (isAdmin) { exitAdmin(); return; }
  document.getElementById('pwInput').value = '';
  document.getElementById('pwError').textContent = '';
  openModal('pwModal');
  setTimeout(() => document.getElementById('pwInput').focus(), 100);
}

function checkPassword() {
  const val = document.getElementById('pwInput').value;
  if (val === ADMIN_CODE) {
    isAdmin = true;
    localStorage.setItem('mtrx_admin', 'true');
    closeModal('pwModal');
    activateAdmin();
    toast('Modo Admin ativado ⚡', 'success');
  } else {
    document.getElementById('pwError').textContent = 'Código incorreto. Tente novamente.';
    document.getElementById('pwInput').value = '';
    document.getElementById('pwInput').focus();
  }
}

function activateAdmin() {
  document.body.classList.add('admin-mode');
  document.getElementById('adminBadge').classList.add('visible');
  document.getElementById('adminPanel').classList.add('visible');
  document.getElementById('adminToggleBtn').textContent = '⚿ Sair';
}

function exitAdmin() {
  isAdmin = false;
  localStorage.removeItem('mtrx_admin');
  document.body.classList.remove('admin-mode');
  document.getElementById('adminBadge').classList.remove('visible');
  document.getElementById('adminPanel').classList.remove('visible');
  document.getElementById('adminToggleBtn').textContent = '⚿ Admin';
  toast('Modo Admin desativado');
}

// ─────────────────────────────────────────────
// FILTERS
// ─────────────────────────────────────────────
function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderAll();
}

// ─────────────────────────────────────────────
// RENDER
// ─────────────────────────────────────────────
function renderAll() {
  renderFeatured();
  renderCategories();
}

function renderFeatured() {
  const strip = document.getElementById('featuredStrip');
  const section = document.getElementById('featuredSection');
  const search = document.getElementById('searchInput').value.toLowerCase();

  const featured = [];
  db.categories.forEach(cat => {
    cat.subcategories.forEach(sub => {
      sub.prompts.forEach(p => {
        if (p.featured) featured.push({...p, catType: cat.type});
      });
    });
  });

  if (featured.length === 0 || currentFilter === 'featured') {
    section.style.display = 'none';
    return;
  }
  section.style.display = '';

  strip.innerHTML = featured.map(p => `
    <span class="featured-chip" onclick="scrollToPrompt('${p.id}')">${p.title}</span>
  `).join('');
}

function renderCategories() {
  const content = document.getElementById('mainContent');
  const search = document.getElementById('searchInput').value.toLowerCase();

  let html = '';
  let totalVisible = 0;

  db.categories.forEach(cat => {
    if (currentFilter === 'image' && cat.type !== 'image') return;
    if (currentFilter === 'audio' && cat.type !== 'audio') return;

    let catHtml = '';
    let catVisible = 0;

    cat.subcategories.forEach(sub => {
      const filtered = sub.prompts.filter(p => {
        if (currentFilter === 'featured' && !p.featured) return false;
        if (search && !p.title.toLowerCase().includes(search) &&
            !p.desc.toLowerCase().includes(search) &&
            !p.prompt.toLowerCase().includes(search)) return false;
        return true;
      });

      if (filtered.length === 0 && currentFilter !== 'featured') return;

      catVisible += filtered.length;
      totalVisible += filtered.length;

      catHtml += `
        <div class="subcategory" id="sub_${sub.id}">
          <div class="sub-header">
            <div class="sub-name">${sub.name}</div>
            ${isAdmin ? `<button class="btn-add-sub" onclick="openAddPrompt('${cat.id}','${sub.id}')">＋ Prompt</button>` : ''}
          </div>
          <div class="cards-grid">
            ${filtered.map(p => renderCard(p, cat.id, sub.id)).join('')}
          </div>
        </div>
      `;
    });

    if (!catHtml) return;

    html += `
      <div class="category-block">
        <div class="category-header">
          <div class="category-title">
            <div class="cat-icon ${cat.type}">${cat.icon}</div>
            <div>
              <div class="cat-name">${cat.name}</div>
              <div class="cat-count">${catVisible} prompts</div>
            </div>
          </div>
          ${isAdmin ? `<button class="btn-add-cat" onclick="openAddCategory('${cat.id}')">＋ Nova subcategoria</button>` : ''}
        </div>
        ${catHtml}
      </div>
    `;
  });

  if (!html) {
    html = `<div class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <p>Nenhum prompt encontrado.<br>Tente outro termo ou categoria.</p>
    </div>`;
  }

  content.innerHTML = html;
}

function renderCard(p, catId, subId) {
  return `
    <div class="prompt-card ${p.featured ? 'featured' : ''}" id="card_${p.id}">
      <div class="card-top">
        <div class="card-title">${p.title}</div>
        <div class="card-actions">
          <button class="btn-copy" title="Copiar prompt" onclick="copyPrompt('${p.id}', this)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          </button>
          <button class="btn-fav ${p.featured ? 'active' : ''}" title="${p.featured ? 'Remover da curadoria' : 'Adicionar à curadoria'}" onclick="toggleFeatured('${catId}','${subId}','${p.id}')">
            ${p.featured ? '★' : '☆'}
          </button>
          <button class="btn-edit" title="Editar" onclick="openEditPrompt('${catId}','${subId}','${p.id}')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="btn-delete" title="Deletar" onclick="deletePrompt('${catId}','${subId}','${p.id}')">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="m19 6-.867 12.142A2 2 0 0 1 16.138 20H7.862a2 2 0 0 1-1.995-1.858L5 6m5 0V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>
          </button>
        </div>
      </div>
      <div class="card-desc">${p.desc}</div>
      <div class="card-prompt" onclick="copyPromptText('${p.id}')" title="Clique para copiar">
        ${p.prompt}
        <span class="prompt-copied-msg" id="copied_${p.id}">Copiado!</span>
      </div>
      <div class="card-tags">
        ${p.featured ? '<span class="tag featured-tag">★ Curadoria</span>' : ''}
      </div>
    </div>
  `;
}

// ─────────────────────────────────────────────
// COPY
// ─────────────────────────────────────────────
function getPromptById(id) {
  for (const cat of db.categories) {
    for (const sub of cat.subcategories) {
      const p = sub.prompts.find(p => p.id === id);
      if (p) return p;
    }
  }
  return null;
}

function copyPromptText(id) {
  const p = getPromptById(id);
  if (!p) return;
  navigator.clipboard.writeText(p.prompt).then(() => {
    const el = document.getElementById('copied_' + id);
    if (el) { el.style.opacity = '1'; setTimeout(() => el.style.opacity = '0', 1200); }
  });
}

function copyPrompt(id, btn) {
  const p = getPromptById(id);
  if (!p) return;
  navigator.clipboard.writeText(p.prompt).then(() => {
    toast('Prompt copiado!', 'success');
  });
}

// ─────────────────────────────────────────────
// FEATURED TOGGLE
// ─────────────────────────────────────────────
function toggleFeatured(catId, subId, promptId) {
  const cat = db.categories.find(c => c.id === catId);
  if (!cat) return;
  const sub = cat.subcategories.find(s => s.id === subId);
  if (!sub) return;
  const p = sub.prompts.find(p => p.id === promptId);
  if (!p) return;
  p.featured = !p.featured;
  saveDB();
  renderAll();
  toast(p.featured ? '★ Adicionado à curadoria' : 'Removido da curadoria', 'success');
}

// ─────────────────────────────────────────────
// CRUD
// ─────────────────────────────────────────────
function openAddPrompt(catId, subId) {
  editingPromptRef = { catId, subId, promptId: null };
  document.getElementById('promptModalTitle').innerHTML = 'Adicionar <em>Prompt</em>';
  document.getElementById('formCategory').value = catId;
  document.getElementById('formSubcategory').value = '';
  document.getElementById('formTitle').value = '';
  document.getElementById('formDesc').value = '';
  document.getElementById('formPrompt').value = '';

  // set subname from existing
  const cat = db.categories.find(c => c.id === catId);
  if (cat) {
    const sub = cat.subcategories.find(s => s.id === subId);
    if (sub) document.getElementById('formSubcategory').value = sub.name;
  }

  openModal('promptModal');
}

function openEditPrompt(catId, subId, promptId) {
  editingPromptRef = { catId, subId, promptId };
  const cat = db.categories.find(c => c.id === catId);
  const sub = cat?.subcategories.find(s => s.id === subId);
  const p = sub?.prompts.find(p => p.id === promptId);
  if (!p) return;

  document.getElementById('promptModalTitle').innerHTML = 'Editar <em>Prompt</em>';
  document.getElementById('formCategory').value = catId;
  document.getElementById('formSubcategory').value = sub.name;
  document.getElementById('formTitle').value = p.title;
  document.getElementById('formDesc').value = p.desc;
  document.getElementById('formPrompt').value = p.prompt;

  openModal('promptModal');
}

function savePrompt() {
  const title = document.getElementById('formTitle').value.trim();
  const desc = document.getElementById('formDesc').value.trim();
  const prompt = document.getElementById('formPrompt').value.trim();
  const catId = document.getElementById('formCategory').value;
  const subName = document.getElementById('formSubcategory').value.trim();

  if (!title || !prompt) {
    toast('Preencha pelo menos o Nome e o Prompt', 'error');
    return;
  }

  const cat = db.categories.find(c => c.id === catId);
  if (!cat) return;

  const ref = editingPromptRef;

  if (ref.promptId) {
    // EDIT
    const sub = cat.subcategories.find(s => s.id === ref.subId);
    if (!sub) return;
    const p = sub.prompts.find(p => p.id === ref.promptId);
    if (!p) return;
    p.title = title;
    p.desc = desc;
    p.prompt = prompt;
    toast('Prompt atualizado ✓', 'success');
  } else {
    // ADD
    let sub = cat.subcategories.find(s => s.id === ref.subId);
    if (!sub) {
      // create new sub
      sub = { id: genId(), name: subName || 'Nova Subcategoria', prompts: [] };
      cat.subcategories.push(sub);
    }
    sub.prompts.push({
      id: genId(),
      title,
      desc,
      prompt,
      featured: false
    });
    toast('Prompt adicionado ✓', 'success');
  }

  saveDB();
  closeModal('promptModal');
  renderAll();
}

function deletePrompt(catId, subId, promptId) {
  if (!confirm('Deletar este prompt? Esta ação não pode ser desfeita.')) return;
  const cat = db.categories.find(c => c.id === catId);
  const sub = cat?.subcategories.find(s => s.id === subId);
  if (!sub) return;
  sub.prompts = sub.prompts.filter(p => p.id !== promptId);
  saveDB();
  renderAll();
  toast('Prompt deletado', 'error');
}

// ─────────────────────────────────────────────
// SCROLL TO
// ─────────────────────────────────────────────
function scrollToPrompt(id) {
  const el = document.getElementById('card_' + id);
  if (el) {
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    el.style.borderColor = 'var(--accent)';
    setTimeout(() => el.style.borderColor = '', 1500);
  }
}

// ─────────────────────────────────────────────
// MODALS
// ─────────────────────────────────────────────
function openModal(id) {
  document.getElementById(id).classList.add('visible');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('visible');
}

// close on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) closeModal(overlay.id);
  });
});

// ─────────────────────────────────────────────
// TOAST
// ─────────────────────────────────────────────
let toastTimer;
function toast(msg, type = '') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.className = '', 2500);
}

// ─────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────
if (isAdmin) activateAdmin();
renderAll();
</script>
</body>
</html>
